generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum ReportType {
  FRONT_OFFICE
  DAILY_EXPENSE
  PURCHASE
  RESTAURANT_SALES
  BANQUET_EVENT
  CASH_ACCOUNTS
}

model Hotel {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  city        String
  state       String
  country     String
  totalRooms  Int
  currency    String   @default("INR")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  reportBatch ReportBatch[]
}

model User {
  id           String   @id @default(cuid())
  hotelId      String
  fullName     String
  email        String   @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  hotel        Hotel    @relation(fields: [hotelId], references: [id])
  submittedBatches ReportBatch[] @relation("SubmittedBy")
}

model ReportBatch {
  id                    String   @id @default(cuid())
  hotelId               String
  reportDate            DateTime
  submittedByUserId     String
  createdAt             DateTime @default(now())

  dailyTotalSales       Decimal  @db.Decimal(12, 2)
  dailyExpenses         Decimal  @db.Decimal(12, 2)
  cashInflow            Decimal  @db.Decimal(12, 2)
  cashOutflow           Decimal  @db.Decimal(12, 2)
  upiReceived           Decimal  @db.Decimal(12, 2)
  cardReceived          Decimal  @db.Decimal(12, 2)
  bankTransferReceived  Decimal  @db.Decimal(12, 2)

  otaRevenue            Decimal  @db.Decimal(12, 2)
  directBookingRevenue  Decimal  @db.Decimal(12, 2)
  restaurantRevenue     Decimal  @db.Decimal(12, 2)
  banquetRevenue        Decimal  @db.Decimal(12, 2)
  roomRevenue           Decimal  @db.Decimal(12, 2)

  roomsAvailable        Int
  roomsSold             Int

  frontOfficeReport     Json
  expenseReport         Json
  purchaseReport        Json
  restaurantReport      Json
  banquetReport         Json
  cashAccountsReport    Json

  hotel                 Hotel    @relation(fields: [hotelId], references: [id])
  submittedBy           User     @relation("SubmittedBy", fields: [submittedByUserId], references: [id])

  @@unique([hotelId, reportDate])
  @@index([hotelId, reportDate])
}
